PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_EXPIRES_IN=2h
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
FRONTEND_URL=http://localhost:3000
LOCAL_AI_SERVICE_URL=http://localhost:5001
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=5001
AI_SERVICE_TOKEN=replace-with-a-random-internal-service-token
HF_API_KEY=replace-with-your-hugging-face-token
HF_FALLBACK_MODEL=google/flan-t5-base
MAX_UPLOAD_SIZE_BYTES=10485760
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
